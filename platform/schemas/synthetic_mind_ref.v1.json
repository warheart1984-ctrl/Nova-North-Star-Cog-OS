{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform.synthetic_mind_ref.v1",
  "title": "Synthetic Mind Reference v1",
  "description": "Read-only platform index entry for a deployed Nova Cortex + Spark bundle (no cognition execution in platform/).",
  "type": "object",
  "required": [
    "ref_version",
    "org_id",
    "build_id",
    "bundle_hash",
    "family_id",
    "deploy_target",
    "claim_label",
    "registered_at"
  ],
  "properties": {
    "ref_version": { "const": "platform.synthetic_mind_ref.v1" },
    "org_id": { "type": "string" },
    "build_id": { "type": "string" },
    "bundle_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "family_id": { "type": "string" },
    "family_version": { "type": "string" },
    "spark_pipeline_id": { "type": "string" },
    "deploy_target": {
      "enum": ["wolf_payload", "forge_inject", "artifact_index", "dry_run"]
    },
    "storage_uri": { "type": "string" },
    "job_id": { "type": "string" },
    "claim_label": { "enum": ["asserted", "proven", "rejected"] },
    "read_only_projection_sample": {
      "type": "object",
      "properties": {
        "projection_version": { "type": "string" },
        "read_only": { "const": true }
      }
    },
    "registered_at": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object" }
  }
}
