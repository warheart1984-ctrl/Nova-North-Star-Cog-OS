{
  "defaults": {
    "base_url": "http://127.0.0.1:8000",
    "legacy_base_url": "http://127.0.0.1:5000",
    "runtime_mount_path": "/legacy_api"
  },
  "routes": {
    "health": "/health",
    "jarvis_chat": "/api/jarvis",
    "jarvis_sessions": "/legacy_api/api/chat/sessions",
    "jarvis_message": "/legacy_api/api/chat/sessions/{session_id}/message",
    "jarvis_stream": "/legacy_api/api/chat/sessions/{session_id}/stream",
    "memory_write": "/api/memory/write"
  }
}
