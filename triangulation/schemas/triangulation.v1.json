{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "triangulation.v1",
  "title": "Forensic Triangulation Ledger v1",
  "description": "Correlates Mechanic, Scorpion, and optional Slingshot diagnostic claims per case_id.",
  "type": "object",
  "required": [
    "triangulation_version",
    "case_id",
    "sources",
    "claims",
    "correlation_edges",
    "cisiv_stage",
    "claim_label",
    "created_at_utc"
  ],
  "properties": {
    "triangulation_version": { "const": "triangulation.v1" },
    "case_id": { "type": "string", "minLength": 1 },
    "sources": { "type": "object" },
    "claims": { "type": "array" },
    "correlation_edges": { "type": "array" },
    "cisiv_stage": {
      "enum": ["concept", "identity", "structure", "implementation", "verification"]
    },
    "claim_label": { "enum": ["asserted", "proven", "rejected"] },
    "summary": { "type": "string", "maxLength": 500 },
    "created_at_utc": { "type": "string" },
    "updated_at_utc": { "type": "string" },
    "launch_blocked": { "type": "boolean" }
  }
}
