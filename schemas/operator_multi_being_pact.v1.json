{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_multi_being_pact.v1.json",
  "title": "OperatorMultiBeingPact",
  "type": "object",
  "required": ["pact_version", "pact_id", "pact_kind", "summary", "claim_label"],
  "properties": {
    "pact_version": {"const": "operator_multi_being_pact.v1"},
    "pact_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "pact_kind": {
      "enum": ["bilateral_organism", "cross_machine_peer", "federated_mesh_cluster", "governance_cosign", "closure"]
    },
    "counterparty_organism_ref": {"type": "object"},
    "continuity_posture": {"type": "string"},
    "trust_tier": {"type": "string"},
    "summary": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_layers": {"type": "object"},
    "identity_alignment": {"type": "boolean"},
    "narrative_alignment": {"type": "boolean"},
    "agency_alignment": {"type": "boolean"},
    "social_alignment": {"type": "boolean"},
    "stability_score": {"type": "number"},
    "digest_verified": {"type": "boolean"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "mbc_class": {"enum": ["MBC-0", "MBC-1", "MBC-2", "MBC-3"]}
  },
  "additionalProperties": true
}
