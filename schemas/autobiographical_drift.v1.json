{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "autobiographical_drift.v1.json",
  "title": "AutobiographicalDrift",
  "type": "object",
  "required": ["drift_version", "drift_id", "severity"],
  "properties": {
    "drift_version": {"const": "autobiographical_drift.v1"},
    "drift_id": {"type": "string"},
    "severity": {"enum": ["nominal", "attention", "conflict"]},
    "source": {"type": "string"},
    "summary": {"type": "string"},
    "identity_aligned": {"type": "boolean"},
    "narrative_aligned": {"type": "boolean"},
    "aac_class": {"enum": ["AAC-0", "AAC-1", "AAC-2", "AAC-3"]}
  },
  "additionalProperties": true
}
