{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-infinity.local/schemas/operator_federated_epoch_charter.v1.json",
  "title": "operator_federated_epoch_charter.v1",
  "type": "object",
  "required": ["charter_version", "epoch_id", "coordination_class", "summary"],
  "properties": {
    "charter_version": { "const": "operator_federated_epoch_charter.v1" },
    "epoch_id": { "type": "string", "minLength": 1 },
    "coordination_class": { "enum": ["FCE-0", "FCE-1", "FCE-2", "FCE-3"] },
    "summary": { "type": "string", "minLength": 1 },
    "tenant_ids": { "type": "array", "items": { "type": "string" } },
    "peer_base_urls": { "type": "array", "items": { "type": "string", "format": "uri" } },
    "population_member_count": { "type": "integer", "minimum": 0 },
    "external_witnesses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["witness_id", "witness_org_domain"],
        "properties": {
          "witness_id": { "type": "string" },
          "witness_org_domain": { "type": "string" },
          "trust_bundle_ref": { "type": "string" },
          "signed_at": { "type": "string" }
        }
      }
    },
    "upstream_refs": {
      "type": "object",
      "properties": {
        "gcv_charter_id": { "type": "string" },
        "isd_accord_id": { "type": "string" },
        "nfd_treaty_id": { "type": "string" },
        "cev_amendment_id": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
