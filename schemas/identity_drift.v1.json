{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "identity_drift.v1.json",
  "title": "IdentityDrift",
  "type": "object",
  "required": ["drift_version", "drift_id", "severity"],
  "properties": {
    "drift_version": {"const": "identity_drift.v1"},
    "drift_id": {"type": "string"},
    "severity": {"enum": ["nominal", "attention", "conflict"]},
    "source": {"type": "string"},
    "summary": {"type": "string"},
    "anchor_aligned": {"type": "boolean"},
    "icc_class": {"enum": ["ICC-0", "ICC-1", "ICC-2", "ICC-3"]}
  },
  "additionalProperties": true
}
