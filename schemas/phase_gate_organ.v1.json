{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase_gate_organ.v1",
  "title": "Phase Gate Organ v1",
  "type": "object",
  "required": [
    "phase_gate_organ_version",
    "module_id",
    "registered_count",
    "cisiv_stage",
    "claim_label"
  ],
  "properties": {
    "phase_gate_organ_version": { "const": "phase_gate_organ.v1" },
    "module_id": { "type": "string", "minLength": 1 },
    "registered_count": { "type": "integer", "minimum": 0 },
    "phase_histogram": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "last_violation_summary": { "type": "string" },
    "cisiv_stage": {
      "enum": ["concept", "identity", "structure", "implementation", "verification"]
    },
    "claim_label": { "enum": ["asserted", "proven", "rejected"] },
    "read_only": { "type": "boolean" }
  },
  "additionalProperties": false
}
