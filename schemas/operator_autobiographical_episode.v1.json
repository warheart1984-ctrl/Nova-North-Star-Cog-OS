{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_autobiographical_episode.v1.json",
  "title": "OperatorAutobiographicalEpisode",
  "type": "object",
  "required": ["episode_version", "episode_id", "episode_kind", "summary", "claim_label"],
  "properties": {
    "episode_version": {"const": "operator_autobiographical_episode.v1"},
    "episode_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "episode_kind": {"enum": ["ongoing_work", "commitment_arc", "operator_partnership", "closure"]},
    "summary": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_layers": {"type": "object"},
    "identity_alignment": {"type": "boolean"},
    "narrative_alignment": {"type": "boolean"},
    "stability_score": {"type": "number"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "aac_class": {"enum": ["AAC-0", "AAC-1", "AAC-2", "AAC-3"]}
  },
  "additionalProperties": true
}
