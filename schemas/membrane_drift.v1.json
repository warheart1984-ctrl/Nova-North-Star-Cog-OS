{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "membrane_drift.v1.json",
  "title": "MembraneDrift",
  "type": "object",
  "required": ["drift_version", "drift_id", "severity", "source", "summary"],
  "properties": {
    "drift_version": {"const": "membrane_drift.v1"},
    "drift_id": {"type": "string"},
    "severity": {"enum": ["nominal", "attention", "critical"]},
    "source": {"type": "string"},
    "summary": {"type": "string"},
    "mgm_class": {"enum": ["MGM-0", "MGM-1", "MGM-2", "MGM-3"]},
    "observed_at": {"type": "string"}
  },
  "additionalProperties": true
}
