{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_narrative_beat.v1.json",
  "title": "OperatorNarrativeBeat",
  "type": "object",
  "required": ["beat_version", "beat_id", "beat_kind", "summary", "claim_label"],
  "properties": {
    "beat_version": {"const": "operator_narrative_beat.v1"},
    "beat_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "beat_kind": {"enum": ["chapter", "thread", "promise_closure", "arc"]},
    "summary": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_layers": {"type": "object"},
    "identity_alignment": {"type": "boolean"},
    "stability_score": {"type": "number"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "ncc_class": {"enum": ["NCC-0", "NCC-1", "NCC-2", "NCC-3"]}
  },
  "additionalProperties": true
}
