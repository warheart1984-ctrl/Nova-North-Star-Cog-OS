  "$id": "evolution_drift.v1.json",
  "title": "EvolutionDrift",
  "type": "object",
  "required": ["drift_version", "drift_id", "severity", "summary", "cev_class"],
  "properties": {
    "drift_version": {"const": "evolution_drift.v1"},
