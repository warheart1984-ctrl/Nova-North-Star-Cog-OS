{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "organ_mesh_run.v1.json",
  "title": "OrganMeshRun",
  "type": "object",
  "required": ["mesh_run_version", "run_id", "status", "steps"],
  "properties": {
    "mesh_run_version": {"const": "organ_mesh_run.v1"},
    "run_id": {"type": "string"},
    "status": {"enum": ["planned", "running", "completed", "blocked", "failed"]},
    "dry_run": {"type": "boolean"},
    "operator_approved": {"type": "boolean"},
    "jarvis_authorized": {"type": "boolean"},
    "occ_class": {"enum": ["OCC-0", "OCC-1", "OCC-2"]},
    "steps": {"type": "array"},
    "handoffs": {"type": "array"},
    "session_id": {"type": "string"}
  },
  "additionalProperties": true
}
