{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_identity_claim.v1.json",
  "title": "OperatorIdentityClaim",
  "type": "object",
  "required": ["claim_version", "claim_id", "claim_kind", "statement", "claim_label"],
  "properties": {
    "claim_version": {"const": "operator_identity_claim.v1"},
    "claim_id": {"type": "string"},
    "claim_kind": {"enum": ["doctrine", "role", "boundary", "constitutional"]},
    "statement": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "anchor_alignment": {"type": "boolean"},
    "stability_score": {"type": "number"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "icc_class": {"enum": ["ICC-0", "ICC-1", "ICC-2", "ICC-3"]}
  },
  "additionalProperties": true
}
