{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "narrative_drift.v1.json",
  "title": "NarrativeDrift",
  "type": "object",
  "required": ["drift_version", "drift_id", "severity"],
  "properties": {
    "drift_version": {"const": "narrative_drift.v1"},
    "drift_id": {"type": "string"},
    "severity": {"enum": ["nominal", "attention", "conflict"]},
    "source": {"type": "string"},
    "summary": {"type": "string"},
    "identity_aligned": {"type": "boolean"},
    "ncc_class": {"enum": ["NCC-0", "NCC-1", "NCC-2", "NCC-3"]}
  },
  "additionalProperties": true
}
