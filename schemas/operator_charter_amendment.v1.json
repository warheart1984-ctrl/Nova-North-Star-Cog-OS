{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_charter_amendment.v1.json",
  "title": "OperatorCharterAmendment",
  "type": "object",
  "required": ["amendment_version", "amendment_id", "charter_id", "summary", "claim_label"],
  "properties": {
    "amendment_version": {"const": "operator_charter_amendment.v1"},
    "amendment_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "charter_id": {"type": "string"},
    "amendment_kind": {"enum": ["scope_extension", "invariant_clarification", "routing_elevation", "composite"]},
    "tier5_tags": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "cev_class": {"enum": ["CEV-0", "CEV-1", "CEV-2", "CEV-3"]}
  },
  "additionalProperties": true
}
