{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "social_drift.v1.json",
  "title": "SocialDrift",
  "type": "object",
  "required": ["drift_version", "drift_id", "severity"],
  "properties": {
    "drift_version": {"const": "social_drift.v1"},
    "drift_id": {"type": "string"},
    "severity": {"enum": ["nominal", "attention", "conflict"]},
    "source": {"type": "string"},
    "summary": {"type": "string"},
    "identity_aligned": {"type": "boolean"},
    "narrative_aligned": {"type": "boolean"},
    "agency_aligned": {"type": "boolean"},
    "scc_class": {"enum": ["SCC-0", "SCC-1", "SCC-2", "SCC-3"]}
  },
  "additionalProperties": true
}
