{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_social_bond.v1.json",
  "title": "OperatorSocialBond",
  "type": "object",
  "required": ["bond_version", "bond_id", "bond_kind", "summary", "claim_label"],
  "properties": {
    "bond_version": {"const": "operator_social_bond.v1"},
    "bond_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "bond_kind": {
      "enum": ["operator_dyad", "federated_peer", "organ_collaborator", "workflow_counterparty", "closure"]
    },
    "counterparty_ref": {"type": "object"},
    "trust_posture": {"type": "string"},
    "summary": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_layers": {"type": "object"},
    "identity_alignment": {"type": "boolean"},
    "narrative_alignment": {"type": "boolean"},
    "agency_alignment": {"type": "boolean"},
    "stability_score": {"type": "number"},
    "interaction_count": {"type": "integer"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "scc_class": {"enum": ["SCC-0", "SCC-1", "SCC-2", "SCC-3"]}
  },
  "additionalProperties": true
}
