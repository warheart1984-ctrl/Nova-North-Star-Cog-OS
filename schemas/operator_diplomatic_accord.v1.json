{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_diplomatic_accord.v1.json",
  "title": "OperatorDiplomaticAccord",
  "type": "object",
  "required": ["accord_version", "accord_id", "accord_kind", "summary", "claim_label"],
  "properties": {
    "accord_version": {"const": "operator_diplomatic_accord.v1"},
    "accord_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "accord_kind": {
      "enum": ["substrate_handoff", "ledger_scope", "memory_overlay", "imxp_envelope", "composite"]
    },
    "charter_ref": {"type": "object"},
    "policy_ref": {"type": "object"},
    "substrate_scopes": {"type": "array", "items": {"type": "string"}},
    "consent_requirements": {"type": "object"},
    "summary": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "stability_score": {"type": "number"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "isd_class": {"enum": ["ISD-0", "ISD-1", "ISD-2", "ISD-3"]}
  },
  "additionalProperties": true
}
