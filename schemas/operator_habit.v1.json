{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_habit.v1.json",
  "title": "OperatorHabit",
  "type": "object",
  "required": ["habit_version", "habit_id", "pattern_kind", "claim_label"],
  "properties": {
    "habit_version": {"const": "operator_habit.v1"},
    "habit_id": {"type": "string"},
    "pattern_kind": {"enum": ["chain", "mesh_path", "routine"]},
    "source_family_id": {"type": "string"},
    "target_family_id": {"type": "string"},
    "chain_ids": {"type": "array", "items": {"type": "string"}},
    "occurrence_count": {"type": "integer", "minimum": 0},
    "last_seen_at": {"type": "string"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "hcc_class": {"enum": ["HCC-0", "HCC-1", "HCC-2", "HCC-3"]}
  },
  "additionalProperties": true
}
