{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_civilization_charter.v1.json",
  "title": "OperatorCivilizationCharter",
  "type": "object",
  "required": ["civilization_version", "civilization_id", "summary", "claim_label"],
  "properties": {
    "civilization_version": {"const": "operator_civilization_charter.v1"},
    "civilization_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "admitted_charter_ids": {"type": "array", "items": {"type": "string"}},
    "admitted_accord_ids": {"type": "array", "items": {"type": "string"}},
    "admitted_treaty_ids": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "stability_score": {"type": "number"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "gcv_class": {"enum": ["GCV-0", "GCV-1", "GCV-2", "GCV-3"]}
  },
  "additionalProperties": true
}
