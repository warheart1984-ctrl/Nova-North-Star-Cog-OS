{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_membrane_policy.v1.json",
  "title": "OperatorMembranePolicy",
  "type": "object",
  "required": ["policy_version", "policy_id", "policy_kind", "summary", "claim_label"],
  "properties": {
    "policy_version": {"const": "operator_membrane_policy.v1"},
    "policy_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "policy_kind": {
      "enum": ["memory_permeability", "exchange_permeability", "mesh_permeability", "ledger_permeability", "composite"]
    },
    "charter_ref": {"type": "object"},
    "permitted_channels": {"type": "array", "items": {"type": "string"}},
    "consent_requirements": {"type": "object"},
    "summary": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "stability_score": {"type": "number"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "mgm_class": {"enum": ["MGM-0", "MGM-1", "MGM-2", "MGM-3"]}
  },
  "additionalProperties": true
}
