{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cogos.synthetic_mind_bundle.v1",
  "title": "Synthetic Mind Bundle v1",
  "description": "Portable Nova Cortex + Spark v1 runtime bundle for Wolf, Forge inject, and Platform artifact indexing.",
  "type": "object",
  "required": [
    "bundle_version",
    "family_id",
    "spark_pipeline_id",
    "claim_posture",
    "built_at",
    "files"
  ],
  "properties": {
    "bundle_version": { "const": "synthetic_mind_bundle.v1" },
    "family_id": { "type": "string" },
    "family_version": { "type": "string" },
    "spark_pipeline_id": { "type": "string" },
    "claim_posture": { "enum": ["asserted", "proven", "rejected"] },
    "built_at": { "type": "string", "format": "date-time" },
    "bundle_root": { "type": "string" },
    "bundle_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ai_factory_build_id": { "type": "string" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relative_path", "sha256"],
        "properties": {
          "relative_path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "required_modules": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
