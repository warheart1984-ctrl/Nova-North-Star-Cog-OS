{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_shared_norm.v1.json",
  "title": "OperatorSharedNorm",
  "type": "object",
  "required": ["norm_version", "norm_id", "norm_kind", "summary", "claim_label"],
  "properties": {
    "norm_version": {"const": "operator_shared_norm.v1"},
    "norm_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "norm_kind": {
      "enum": ["handoff_ritual", "consent_cadence", "dispute_posture", "mesh_cluster", "exchange_protocol", "closure"]
    },
    "cluster_ref": {"type": "object"},
    "continuity_posture": {"type": "string"},
    "trust_tier": {"type": "string"},
    "summary": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_layers": {"type": "object"},
    "identity_alignment": {"type": "boolean"},
    "narrative_alignment": {"type": "boolean"},
    "agency_alignment": {"type": "boolean"},
    "social_alignment": {"type": "boolean"},
    "pact_alignment": {"type": "boolean"},
    "stability_score": {"type": "number"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "cob_class": {"enum": ["COB-0", "COB-1", "COB-2", "COB-3"]}
  },
  "additionalProperties": true
}
