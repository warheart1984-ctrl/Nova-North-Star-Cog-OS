{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "nova_touch_event.v1.json",
  "title": "NovaTouchEvent",
  "type": "object",
  "required": ["touch_kind", "session_id"],
  "properties": {
    "touch_kind": {
      "type": "string",
      "enum": ["tap", "swipe", "long_press", "gesture_stub"]
    },
    "session_id": { "type": "string", "minLength": 1 },
    "target": { "type": "string" },
    "coordinates": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "ephemeral": { "type": "boolean", "default": true },
    "maps_to_message": { "type": "string", "maxLength": 4000 }
  },
  "additionalProperties": false
}
