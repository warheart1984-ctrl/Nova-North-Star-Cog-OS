{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_ecosystem_charter.v1.json",
  "title": "OperatorEcosystemCharter",
  "type": "object",
  "required": ["charter_version", "charter_id", "charter_kind", "summary", "claim_label"],
  "properties": {
    "charter_version": {"const": "operator_ecosystem_charter.v1"},
    "charter_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "charter_kind": {"enum": ["federated_cluster", "bilateral_mesh", "governance_cosign", "arbitration_frame", "closure"]},
    "member_organism_refs": {"type": "array", "items": {"type": "object"}},
    "admitted_pact_ids": {"type": "array", "items": {"type": "string"}},
    "admitted_norm_ids": {"type": "array", "items": {"type": "string"}},
    "invariant_set": {"type": "array", "items": {"type": "object"}},
    "arbitration_policy": {"type": "string"},
    "summary": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "stability_score": {"type": "number"},
    "digest_verified": {"type": "boolean"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "cec_class": {"enum": ["CEC-0", "CEC-1", "CEC-2", "CEC-3"]}
  },
  "additionalProperties": true
}
