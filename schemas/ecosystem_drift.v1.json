{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ecosystem_drift.v1.json",
  "title": "EcosystemDrift",
  "type": "object",
  "required": ["drift_version", "drift_id", "severity", "source", "summary"],
  "properties": {
    "drift_version": {"const": "ecosystem_drift.v1"},
    "drift_id": {"type": "string"},
    "severity": {"enum": ["nominal", "attention", "critical"]},
    "source": {"type": "string"},
    "summary": {"type": "string"},
    "cec_class": {"enum": ["CEC-0", "CEC-1", "CEC-2", "CEC-3"]},
    "observed_at": {"type": "string"}
  },
  "additionalProperties": true
}
