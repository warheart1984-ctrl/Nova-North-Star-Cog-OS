{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "substrate_drift.v1.json",
  "title": "SubstrateDrift",
  "type": "object",
  "required": ["drift_version", "drift_id", "severity", "summary", "isd_class"],
  "properties": {
    "drift_version": {"const": "substrate_drift.v1"},
    "drift_id": {"type": "string"},
    "severity": {"enum": ["nominal", "attention", "critical"]},
    "source": {"type": "string"},
    "summary": {"type": "string"},
    "isd_class": {"const": "ISD-0"},
    "observed_at": {"type": "string"}
  },
  "additionalProperties": true
}
