{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_norm_federation_treaty.v1.json",
  "title": "OperatorNormFederationTreaty",
  "type": "object",
  "required": ["treaty_version", "treaty_id", "treaty_kind", "summary", "claim_label"],
  "properties": {
    "treaty_version": {"const": "operator_norm_federation_treaty.v1"},
    "treaty_id": {"type": "string"},
    "candidate_id": {"type": "string"},
    "treaty_kind": {"enum": ["bilateral_norm", "cluster_norm", "ecosystem_norm", "composite"]},
    "adopted_norm_ids": {"type": "array", "items": {"type": "string"}},
    "charter_refs": {"type": "array", "items": {"type": "object"}},
    "summary": {"type": "string"},
    "stability_score": {"type": "number"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "operator_promoted": {"type": "boolean"},
    "nfd_class": {"enum": ["NFD-0", "NFD-1", "NFD-2", "NFD-3"]}
  },
  "additionalProperties": true
}
