{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "organ_handoff.v1.json",
  "title": "OrganHandoff",
  "type": "object",
  "required": ["handoff_version", "source_family_id", "target_family_id", "chain_id"],
  "properties": {
    "handoff_version": {"const": "organ_handoff.v1"},
    "source_family_id": {"type": "string"},
    "target_family_id": {"type": "string"},
    "source_chain_id": {"type": "string"},
    "chain_id": {"type": "string"},
    "artifact_ref": {"type": "string"},
    "ul_substrate": {"type": "object"},
    "claim_label": {"enum": ["asserted", "proven", "rejected"]},
    "occ_class": {"enum": ["OCC-0", "OCC-1", "OCC-2"]},
    "operator_ack_required": {"type": "boolean", "default": false},
    "trigger": {"type": "string"}
  },
  "additionalProperties": true
}
