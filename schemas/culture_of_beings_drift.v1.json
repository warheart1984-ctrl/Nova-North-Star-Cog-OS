{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "culture_of_beings_drift.v1.json",
  "title": "CultureOfBeingsDrift",
  "type": "object",
  "required": ["drift_version", "drift_id", "severity", "source", "summary"],
  "properties": {
    "drift_version": {"const": "culture_of_beings_drift.v1"},
    "drift_id": {"type": "string"},
    "severity": {"enum": ["nominal", "attention", "critical"]},
    "source": {"type": "string"},
    "summary": {"type": "string"},
    "identity_aligned": {"type": "boolean"},
    "narrative_aligned": {"type": "boolean"},
    "agency_aligned": {"type": "boolean"},
    "social_aligned": {"type": "boolean"},
    "pact_aligned": {"type": "boolean"},
    "cob_class": {"enum": ["COB-0", "COB-1", "COB-2", "COB-3"]},
    "observed_at": {"type": "string"}
  },
  "additionalProperties": true
}
