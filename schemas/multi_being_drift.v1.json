{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "multi_being_drift.v1.json",
  "title": "MultiBeingDrift",
  "type": "object",
  "required": ["drift_version", "drift_id", "severity"],
  "properties": {
    "drift_version": {"const": "multi_being_drift.v1"},
    "drift_id": {"type": "string"},
    "severity": {"enum": ["nominal", "attention", "conflict"]},
    "source": {"type": "string"},
    "summary": {"type": "string"},
    "identity_aligned": {"type": "boolean"},
    "narrative_aligned": {"type": "boolean"},
    "agency_aligned": {"type": "boolean"},
    "social_aligned": {"type": "boolean"},
    "mbc_class": {"enum": ["MBC-0", "MBC-1", "MBC-2", "MBC-3"]}
  },
  "additionalProperties": true
}
